# Required: set this to the real movie folder on your server.
# Example:
# ELVERN_MEDIA_ROOT="/srv/media/movies"
ELVERN_MEDIA_ROOT=""

# SQLite database path
ELVERN_DB_PATH="/opt/elvern/backend/data/elvern.db"

# Admin login
# This bootstrap admin account is created only if it does not already exist.
ELVERN_ADMIN_USERNAME="admin"

# Use one of the two password options below:
# 1) Preferred for repeatable deploys: generate with
#    .venv/bin/python -m backend.app.cli hash-password "your-password"
ELVERN_ADMIN_PASSWORD_HASH=""

# 2) Or bootstrap once with a plaintext password from the env file.
#    The app hashes it before storing it in SQLite.
ELVERN_ADMIN_BOOTSTRAP_PASSWORD=""

# Required secret for session token hashing.
# Generate with: openssl rand -hex 32
ELVERN_SESSION_SECRET="replace-with-a-random-64-char-hex-string"
ELVERN_ENABLE_MULTIUSER="true"
ELVERN_PRIVATE_NETWORK_ONLY="true"

# Canonical private origins for daily use across Linux, Windows, and macOS.
# Example:
# ELVERN_PUBLIC_APP_ORIGIN="https://example.tailnet.ts.net"
# ELVERN_BACKEND_ORIGIN="http://example-private-host:8000"
ELVERN_PUBLIC_APP_ORIGIN=""
ELVERN_BACKEND_ORIGIN=""

# Backend API bind
# Use 0.0.0.0 when the backend must be reachable by desktop helpers over the tailnet.
# Keep 127.0.0.1 only for local development fallback.
ELVERN_BIND_HOST="0.0.0.0"
ELVERN_PORT="8000"

# Frontend production server bind
# Use 0.0.0.0 when clients connect directly to the frontend port on the DGX host.
# If you publish the app through Tailscale Serve instead, frontend host can remain local.
ELVERN_FRONTEND_HOST="0.0.0.0"
ELVERN_FRONTEND_PORT="4173"

# Cookie security: keep true when using Tailscale Serve HTTPS.
# Set to false only for explicit local plain-http development fallback.
ELVERN_COOKIE_SECURE="true"

# Startup and scanning
ELVERN_SCAN_ON_STARTUP="true"
ELVERN_ALLOWED_VIDEO_EXTENSIONS=".mp4,.m4v,.mov,.mkv,.webm,.avi"
ELVERN_FFPROBE_PATH="/usr/bin/ffprobe"

# Playback compatibility and transcoding
ELVERN_TRANSCODE_ENABLED="true"
ELVERN_TRANSCODE_DIR="/opt/elvern/backend/data/transcodes"
ELVERN_TRANSCODE_TTL_MINUTES="60"
ELVERN_MAX_CONCURRENT_TRANSCODES="1"
ELVERN_FFMPEG_PATH="/usr/bin/ffmpeg"
#
# Browser Playback defaults to Route 2. Set this to "false" to downgrade new
# Browser Playback sessions back to the legacy stitched-cache engine.
ELVERN_BROWSER_PLAYBACK_ROUTE2_ENABLED="true"

# Native desktop player handoff
ELVERN_NATIVE_PLAYBACK_ENABLED="true"
ELVERN_NATIVE_PLAYBACK_SESSION_MINUTES="20"
ELVERN_NATIVE_PLAYER_PROTOCOL="elvern"
ELVERN_PLAYBACK_TOKEN_TTL_SECONDS="300"

# Desktop VLC playback
ELVERN_DESKTOP_PLAYBACK_MODE="vlc_direct"
ELVERN_VLC_HELPER_PROTOCOL="elvern-vlc"
ELVERN_HELPER_RELEASES_DIR="/opt/elvern/backend/data/helper_releases"
ELVERN_HELPER_DEFAULT_CHANNEL="stable"
ELVERN_VLC_PATH_LINUX="/usr/bin/vlc"
ELVERN_VLC_PATH_WINDOWS=""
ELVERN_VLC_PATH_MAC=""
ELVERN_LIBRARY_ROOT_LINUX="/srv/media/movies"
ELVERN_LIBRARY_ROOT_WINDOWS=""
ELVERN_LIBRARY_ROOT_MAC=""

# Logging and login throttling
ELVERN_LOG_LEVEL="INFO"
ELVERN_LOGIN_WINDOW_SECONDS="300"
ELVERN_LOGIN_MAX_ATTEMPTS="5"
ELVERN_LOGIN_LOCKOUT_SECONDS="600"
